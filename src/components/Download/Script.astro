---
import { useTranslations } from '@i18n/utils';
import type { Lang } from '@i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const GUIDE_URL = 'https://tutorial.ambrosiapay.com/quick-start-script/';
const INSTALL_CMD =
  'curl -fsSL https://raw.githubusercontent.com/olympus-btc/ambrosia/refs/heads/main/scripts/install.sh | bash -s -- --yes';
const INSTALL_CMD_NO_SERVICE =
  'curl -fsSL https://raw.githubusercontent.com/olympus-btc/ambrosia/refs/heads/main/scripts/install.sh | bash -s -- --yes --no-service';
---

<div id="panel-script" data-panel="script" role="tabpanel" hidden>
  <div class="max-w-3xl mx-auto">
    <!-- Description -->
    <div class="p-6 md:p-8 bg-surface-card border border-b-subtle rounded-2xl mb-6">
      <div class="flex items-center gap-4 mb-3">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-green-400/10 text-green-400 shrink-0">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="4 17 10 11 4 5"></polyline>
            <line x1="12" y1="19" x2="20" y2="19"></line>
          </svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-th">{t('dl.script.title')}</h3>
          <p class="text-sm text-tsec mt-1">{t('dl.script.desc')}</p>
        </div>
      </div>
    </div>

    <!-- Commands -->
    <div class="p-6 md:p-8 bg-surface-card border border-b-subtle rounded-2xl mb-6 flex flex-col gap-6">
      <!-- Main command -->
      <div>
        <p class="text-xs font-semibold text-green-400 uppercase tracking-wider mb-2">{t('dl.script.label')}</p>
        <div class="relative">
          <code class="block text-xs font-mono text-tsec bg-code-bg px-3 py-3 rounded-lg overflow-x-auto pr-16">{INSTALL_CMD}</code>
          <button
            class="copy-btn absolute right-2 top-1/2 -translate-y-1/2 text-xs text-td hover:text-green-400 transition-colors px-2 py-1 rounded"
            data-copy={INSTALL_CMD}>Copy</button
          >
        </div>
      </div>

      <!-- Alt command -->
      <div>
        <p class="text-xs font-semibold text-tm uppercase tracking-wider mb-2">{t('dl.script.alt.label')}</p>
        <div class="relative">
          <code class="block text-xs font-mono text-tsec bg-code-bg px-3 py-3 rounded-lg overflow-x-auto pr-16"
            >{INSTALL_CMD_NO_SERVICE}</code
          >
          <button
            class="copy-btn absolute right-2 top-1/2 -translate-y-1/2 text-xs text-td hover:text-green-400 transition-colors px-2 py-1 rounded"
            data-copy={INSTALL_CMD_NO_SERVICE}>Copy</button
          >
        </div>
      </div>
    </div>

    <!-- CTA -->
    <a
      href={GUIDE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-center gap-2 w-full p-4 bg-green-400/10 border border-green-400/20 rounded-2xl text-green-400 font-semibold hover:bg-green-400/15 transition-colors"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
      </svg>
      {t('dl.script.guide')} →
    </a>
  </div>
</div>
