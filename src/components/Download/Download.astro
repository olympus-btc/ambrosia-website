---
import { useTranslations } from '@i18n/utils';
import type { Lang } from '@i18n/ui';
import { fetchLatestRelease, findAssetByPattern, buildVerifyCommand } from '@lib/releases';
import DesktopApp from './DesktopApp.astro';
import Docker from './Docker.astro';
import Script from './Script.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const RELEASES_URL = 'https://github.com/olympus-btc/ambrosia/releases';
const REPO_URL = 'https://github.com/olympus-btc/ambrosia';

const { version: VERSION, assets } = await fetchLatestRelease();
const assetUrl = (pattern: RegExp) => findAssetByPattern(assets, pattern);

const platforms = [
  {
    id: 'linux',
    nameKey: 'dl.linux' as const,
    icon: 'linux' as const,
    arches: [
      {
        labelKey: 'dl.linux.x64' as const,
        files: [
          { ext: '.deb', label: 'Ubuntu, Debian, Linux Mint', url: assetUrl(/ambrosia-pos[_-].*[_-]amd64\.deb$/) },
          { ext: '.rpm', label: 'Fedora, RHEL, openSUSE', url: assetUrl(/ambrosia-pos.*x86_64\.rpm$/) },
          { ext: '.tar.gz', label: 'Universal Linux', url: assetUrl(/ambrosia-pos.*-x64\.tar\.gz$/) },
        ],
      },
      {
        labelKey: 'dl.linux.arm' as const,
        files: [
          { ext: '.deb', label: 'Ubuntu, Debian', url: assetUrl(/ambrosia-pos[_-].*[_-]arm64\.deb$/) },
          { ext: '.rpm', label: 'Fedora ARM', url: assetUrl(/ambrosia-pos.*aarch64\.rpm$/) },
          { ext: '.tar.gz', label: 'Universal ARM', url: assetUrl(/ambrosia-pos.*-arm64\.tar\.gz$/) },
        ],
      },
    ],
    verifyCmd: buildVerifyCommand('linux', VERSION),
  },
  {
    id: 'windows',
    nameKey: 'dl.windows' as const,
    icon: 'windows' as const,
    arches: [
      {
        labelKey: 'dl.windows.x64' as const,
        files: [
          { ext: '.exe', label: 'Windows 10/11 Installer', url: assetUrl(/ambrosia-pos.*-x64-setup\.exe$/) },
          { ext: '.zip', label: 'Windows 10/11 Portable', url: assetUrl(/ambrosia-pos.*-x64\.zip$/) },
        ],
      },
      {
        labelKey: 'dl.windows.arm' as const,
        files: [
          { ext: '.exe', label: 'Windows 10/11 ARM Installer', url: assetUrl(/ambrosia-pos.*-arm64-setup\.exe$/) },
          { ext: '.zip', label: 'Windows 10/11 ARM Portable', url: assetUrl(/ambrosia-pos.*-arm64\.zip$/) },
        ],
      },
    ],
    verifyCmd: buildVerifyCommand('windows', VERSION),
  },
  {
    id: 'macos',
    nameKey: 'dl.macos' as const,
    icon: 'macos' as const,
    arches: [
      {
        labelKey: 'dl.macos.x64' as const,
        files: [{ ext: '.dmg', label: 'macOS 11+ Installer', url: assetUrl(/ambrosia-pos.*-x64\.dmg$/) }],
      },
      {
        labelKey: 'dl.macos.arm' as const,
        files: [{ ext: '.dmg', label: 'macOS 11+ Installer', url: assetUrl(/ambrosia-pos.*-arm64\.dmg$/) }],
      },
    ],
    verifyCmd: buildVerifyCommand('macos', VERSION),
  },
];
---

<section id="download" class="py-20 md:py-28 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-10 md:mb-14">
      <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-th mb-4">
        {t('dl.header')}
      </h2>
      <p class="text-base md:text-lg text-tsec max-w-2xl mx-auto mb-6">
        {t('dl.subheader')}
      </p>
      <div class="inline-flex items-center gap-3 flex-wrap justify-center text-sm">
        <span class="px-3 py-1.5 bg-green-400/10 border border-green-400/20 rounded-full text-green-400 font-mono font-medium">
          {t('dl.version')}: {VERSION}
        </span>
        <a href={RELEASES_URL} target="_blank" rel="noopener noreferrer" class="dl-link text-tsec hover:text-green-400 transition-colors">
          {t('dl.changelog')}
        </a>
        <a href={REPO_URL} target="_blank" rel="noopener noreferrer" class="dl-link text-tsec hover:text-green-400 transition-colors">
          {t('dl.source')}
        </a>
      </div>
    </div>

    <!-- Tab Switcher -->
    <div class="flex gap-2 md:gap-3 justify-center mb-10 flex-wrap" role="tablist">
      <button
        data-tab="desktop"
        class="tab-btn active flex items-center gap-2 px-5 py-2.5 rounded-xl border text-sm font-semibold transition-all"
        role="tab"
        aria-selected="true"
        aria-controls="panel-desktop"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2"></rect>
          <line x1="8" y1="21" x2="16" y2="21"></line>
          <line x1="12" y1="17" x2="12" y2="21"></line>
        </svg>
        {t('dl.tab.desktop')}
      </button>
      <button
        data-tab="docker"
        class="tab-btn flex items-center gap-2 px-5 py-2.5 rounded-xl border text-sm font-semibold transition-all"
        role="tab"
        aria-selected="false"
        aria-controls="panel-docker"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path
            d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
          ></path>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
          <line x1="12" y1="22.08" x2="12" y2="12"></line>
        </svg>
        {t('dl.tab.docker')}
      </button>
      <button
        data-tab="script"
        class="tab-btn flex items-center gap-2 px-5 py-2.5 rounded-xl border text-sm font-semibold transition-all"
        role="tab"
        aria-selected="false"
        aria-controls="panel-script"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="4 17 10 11 4 5"></polyline>
          <line x1="12" y1="19" x2="20" y2="19"></line>
        </svg>
        {t('dl.tab.script')}
      </button>
    </div>

    <!-- Panels -->
    <DesktopApp lang={lang} platforms={platforms} />
    <Docker lang={lang} />
    <Script lang={lang} />
  </div>
</section>

<style>
  .tab-btn {
    border-color: var(--color-border-subtle, rgb(255 255 255 / 0.08));
    background-color: var(--color-surface-card, rgb(255 255 255 / 0.03));
    color: var(--color-text-muted, rgb(156 163 175));
  }
  .tab-btn:hover:not(.active) {
    border-color: rgb(74 222 128 / 0.15);
    color: var(--color-text-secondary, rgb(209 213 219));
  }
  .tab-btn.active {
    border-color: rgb(74 222 128 / 0.25);
    background-color: rgb(74 222 128 / 0.1);
    color: rgb(74 222 128);
  }
</style>

<script>
  // Tab switching
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');

  function activateTab(target: string) {
    tabBtns.forEach((btn) => {
      const isActive = btn.dataset.tab === target;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-selected', String(isActive));
    });
    panels.forEach((panel) => {
      panel.hidden = panel.dataset.panel !== target;
    });
  }

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => activateTab(btn.dataset.tab!));
  });

  // Copy to clipboard
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.copy ?? '';
      navigator.clipboard.writeText(text).then(() => {
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        btn.style.color = 'rgb(74 222 128)';
        setTimeout(() => {
          btn.textContent = original;
          btn.style.color = '';
        }, 2000);
      });
    });
  });
</script>
