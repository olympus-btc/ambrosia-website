---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero/Hero.astro';
import Features from '../../components/Features.astro';
import WhyAmbrosia from '../../components/WhyAmbrosia/WhyAmbrosia.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import OpenSource from '../../components/OpenSource.astro';
import Download from '../../components/Download/Download.astro';
import { useTranslations } from '../../i18n/utils';
import { languages, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<Layout lang={lang} title={t('meta.title')} description={t('meta.description')}>
  <Hero lang={lang} />
  <Features lang={lang} />
  <WhyAmbrosia lang={lang} />
  <HowItWorks lang={lang} />
  <OpenSource lang={lang} />
  <Download lang={lang} />
</Layout>
